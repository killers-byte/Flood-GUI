-- Helper: Toggle
local function AddToggle(tabIdx, name, stateKey)
    local f = Instance.new("Frame", tabContents[tabIdx].scroll)
    f.Size = UDim2.new(1, -4, 0, 44); f.BackgroundColor3 = ELEMENT; corner(f, 8)
    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(0.7, 0, 1, 0); lbl.Position = UDim2.new(0, 15, 0, 0)
    lbl.Text = name; lbl.TextColor3 = TEXT_W; lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 12; lbl.BackgroundTransparency = 1; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local sb = Instance.new("Frame", f)
    sb.Size = UDim2.new(0, 42, 0, 22); sb.Position = UDim2.new(1, -55, 0.5, -11)
    sb.BackgroundColor3 = BG; corner(sb, 11)
    local dot = Instance.new("Frame", sb)
    dot.Size = UDim2.new(0, 18, 0, 18); dot.Position = UDim2.new(0, 2, 0.5, -9)
    dot.BackgroundColor3 = TEXT_D; corner(dot, 9)
    local click = Instance.new("TextButton", f)
    click.Size = UDim2.new(1,0,1,0); click.BackgroundTransparency = 1; click.Text = ""
    local state = false

    local function setUI(st)
        state = st
        TweenFast(dot, {
            Position = st and UDim2.new(0, 22, 0.5, -9) or UDim2.new(0, 2, 0.5, -9),
            BackgroundColor3 = st and Color3.fromRGB(255,255,255) or TEXT_D
        })
        TweenFast(sb, {BackgroundColor3 = st and ACCENT or BG})
    end
    if stateKey then _G.ToggleStates[stateKey] = { state = false, SetState = setUI } end

    click.MouseButton1Click:Connect(function()
        state = not state; setUI(state)
        if stateKey == "AUTO_QUEUE" then
            STATE.AUTO_QUEUE_ENABLED = state
            if state then CONFIG.TAS_MODE = "Play"; CONFIG.TAS_AUTO_START = true; STATE.mapCompleted = false; StartAutoQueue() else StopAutoQueue() end
        elseif stateKey == "AutoFarm" then
            getgenv().TomatoAutoFarm = state
            if state then StartWinEngine() else StopWinEngine() end
        elseif stateKey == "PANIC_MODE" then
            if state then activatePanicMode() else deactivatePanicMode() end
        else
            CONFIG[stateKey] = state
        end
    end)
end

