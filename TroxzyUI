-- Update Dashboard (dipanggil dari loop lambat backend)
function API.UIHooks.updateDashboard()
    if not Main.Visible then return end
    local remaining = keyExpireTime - GetRealTime()
    if remaining <= 0 then keyLabel.Text = "EXPIRED"; keyLabel.TextColor3 = Color3.fromRGB(255,50,50)
    elseif keyExpireTime > GetRealTime() + 315360000 then keyLabel.Text = "PERMANENT"; keyLabel.TextColor3 = M_ACCENT
    else
        local d = math.floor(remaining/86400); local h = math.floor((remaining%86400)/3600); local m = math.floor((remaining%3600)/60)
        keyLabel.Text = (d>0 and d.."d " or "")..h.."h "..m.."m"; keyLabel.TextColor3 = M_ACCENT
    end
    mapLabel.Text = Stats.currentMap ~= "" and Stats.currentMap or "Waiting..."
    timeLabel.Text = math.floor((os.clock() - Stats.sessionStart)/60) .. "m"
    local hours = (os.clock() - Stats.sessionStart)/3600
    speedLabel.Text = (hours>0 and Stats.mapsCompleted>0 and math.floor(Stats.mapsCompleted/hours) or 0) .. " maps/hr"
    
    if STATE.panicActive then statusLabel.Text = "PANIC"; statusLabel.TextColor3 = Color3.fromRGB(255,80,80)
    elseif STATE.TAS_RUNNING then statusLabel.Text = "TAS PLAYING"; statusLabel.TextColor3 = M_ACCENT
    elseif STATE.AUTO_QUEUE_ENABLED then statusLabel.Text = "Auto Queue"; statusLabel.TextColor3 = Color3.fromRGB(100,200,255)
    else statusLabel.Text = "Idle"; statusLabel.TextColor3 = M_TEXT_D end
    
    ghostLabel.Text = STATE.isGhostMode and "ACTIVE" or "Inactive"
    ghostLabel.TextColor3 = STATE.isGhostMode and Color3.fromRGB(255,50,50) or M_TEXT_D
    
    local admins = getAdminPlayers()
    if #admins > 0 then
        local names = {}; for _, a in ipairs(admins) do table.insert(names, a.Name) end
        adminLabel.Text = table.concat(names, ", "); adminLabel.TextColor3 = Color3.fromRGB(255,80,80)
    else adminLabel.Text = "None"; adminLabel.TextColor3 = Color3.fromRGB(100,255,100) end
    
    local specs = getSpectators()
    if #specs > 0 then
        local names = {}; for _, s in ipairs(specs) do if s.Parent then table.insert(names, s.Name) end end
        specLabel.Text = #names>0 and table.concat(names, ", ") or "None"
        specLabel.TextColor3 = #names>0 and Color3.fromRGB(255,200,0) or M_TEXT_D
    else specLabel.Text = "None"; specLabel.TextColor3 = M_TEXT_D end
    
    fpsLabel.Text = API.getFPS()
    pingLabel.Text = API.getPing().."ms"
    memLabel.Text = math.floor(API.getMemory()).." KB"
    local exp, coin = API.getSessionProfit()
    profitLabel.Text = exp.." EXP / "..coin.." Coin"
end

