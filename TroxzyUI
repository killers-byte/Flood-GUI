local function updateDashboard()
    if getgenv().keyType == "owner" then
        dKeyLabel.Text = "🔑 Key: OWNER"
        dKeyLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
    else
        local rem = keyExpireTime - GetRealTime()
        if rem <= 0 then
            dKeyLabel.Text = "🔑 Key: EXPIRED"
            dKeyLabel.TextColor3 = Color3.fromRGB(255,80,80)
        elseif keyExpireTime > GetRealTime() + 315360000 then
            dKeyLabel.Text = "🔑 Key: PERMANENT"
            dKeyLabel.TextColor3 = ACCENT
        else
            local d = math.floor(rem/86400)
            local h = math.floor((rem%86400)/3600)
            local m = math.floor((rem%3600)/60)
            dKeyLabel.Text = "🔑 Expires In: " .. (d>0 and d.."d " or "") .. h.."h "..m.."m"
            dKeyLabel.TextColor3 = Color3.fromRGB(255,200,100)
        end
    end

    dMapLabel.Text = "📍 Map: " .. (Stats.currentMap ~= "" and Stats.currentMap or "Waiting...")
    dTimeLabel.Text = "⏱️ Time: " .. math.floor((os.clock()-Stats.sessionStart)/60) .. "m"
    local hrs = (os.clock()-Stats.sessionStart)/3600
    dRateLabel.Text = "📈 Rate: " .. (hrs>0 and Stats.mapsCompleted>0 and math.floor(Stats.mapsCompleted/hrs) or 0) .. " maps/hr"

    if STATE.panicActive then
        dStatusLabel.Text = "🌐 Status: PANIC"
        dStatusLabel.TextColor3 = Color3.fromRGB(255,80,80)
    elseif STATE.TAS_RUNNING then
        dStatusLabel.Text = "🌐 Status: TAS PLAYING"
        dStatusLabel.TextColor3 = ACCENT
    elseif STATE.AUTO_QUEUE_ENABLED then
        dStatusLabel.Text = "🌐 Status: Auto Queue"
        dStatusLabel.TextColor3 = Color3.fromRGB(100,200,255)
    else
        dStatusLabel.Text = "🌐 Status: Idle"
        dStatusLabel.TextColor3 = TEXT_D
    end

    if STATE.isGhostMode then
        dGhostLabel.Text = "👻 Ghost Mode: ACTIVE"
        dGhostLabel.TextColor3 = Color3.fromRGB(255,50,50)
    else
        dGhostLabel.Text = "👻 Ghost Mode: Inactive"
        dGhostLabel.TextColor3 = Color3.fromRGB(180,180,180)
    end

    local admins = getAdminPlayers()
    if #admins>0 then
        local n = {}
        for _,a in ipairs(admins) do n[#n+1]=a.Name end
        dAdminLabel.Text = "🚨 Admins: " .. table.concat(n, ", ")
        dAdminLabel.TextColor3 = Color3.fromRGB(255,80,80)
    else
        dAdminLabel.Text = "🚨 Admins: None"
        dAdminLabel.TextColor3 = Color3.fromRGB(100,255,100)
    end
    
    -- 💥 NGEBACA DATA HASIL SCRAPING DARI BACKEND SECARA LIVE 💥
    if API.LiveStats then
        lblLevel.Text = "⭐ Level: " .. tostring(API.LiveStats.Level)
        lblRebirth.Text = "🔄 Kelahiran Kembali: x" .. tostring(API.LiveStats.Rebirths)
        lblXP.Text = "✨ XP: " .. tostring(API.LiveStats.XP)
        lblCoins.Text = "💰 Koin: " .. tostring(API.LiveStats.Coins)
        lblGems.Text = "💎 Gems: " .. tostring(API.LiveStats.Gems)
    end
end

API.UIHooks.updateDashboard = updateDashboard
