-- Minimize/Maximize
local isMinimized = false
local function minimizeUI(instant)
    isMinimized = true
    if instant then MainScale.Scale = 0; Main.Visible = false
    else
        local t = TweenService:Create(MainScale, TweenInfo.new(0.15, Enum.EasingStyle.Sine), { Scale = 0 })
        t:Play(); t.Completed:Connect(function() if isMinimized then Main.Visible = false end end)
    end
end
local function maximizeUI()
    isMinimized = false; Main.Visible = true
    TweenService:Create(MainScale, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1 }):Play()
end
ToggleBtn.MouseButton1Click:Connect(function() if isMinimized then maximizeUI() else minimizeUI(false) end end)

