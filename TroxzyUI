    end)
    b.MouseLeave:Connect(function()
        TweenFast(b, {BackgroundColor3 = isRed and Color3.fromRGB(200, 50, 50) or BG})
    end)
    b.MouseButton1Click:Connect(function() pcall(callback) end)
end

